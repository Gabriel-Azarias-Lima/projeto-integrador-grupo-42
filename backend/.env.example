# Banco de dados PostgreSQL
# Local:
# DATABASE_URL="postgresql://usuario:senha@localhost:5432/studio_elegance"
#
# Supabase — Transaction pooler (IPv4, porta 6543): o app ajusta automaticamente
# pgbouncer=true, connection_limit=1 e timeouts. Você pode também colar a URL já completa:
# DATABASE_URL="postgresql://postgres.[ref]:[senha]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# Migrations (prisma migrate): use a conexão "Direct" (porta 5432) no Supabase como DIRECT_URL
# se o migrate falhar pelo pooler; em schema.prisma adicione directUrl = env("DIRECT_URL") se precisar.
DATABASE_URL="postgresql://usuario:senha@localhost:5432/studio_elegance"

# JWT
JWT_SECRET="troque-por-uma-chave-secreta-forte-e-aleatoria"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=development

# CORS — origem permitida (frontend)
CORS_ORIGIN="http://127.0.0.1:5500"
